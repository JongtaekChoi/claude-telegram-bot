<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cube.claudebot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/jtchoi/.nvm/versions/node/v23.1.0/bin/node</string>
        <string>/Users/jtchoi/Projects/cube-brain-trainer/tools/claude-telegram-bot/bot.mjs</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/jtchoi/Projects/cube-brain-trainer</string>

    <!-- nvm node/claude 경로를 PATH 에 포함 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/jtchoi/.nvm/versions/node/v23.1.0/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- 죽으면 자동 재시작, 로그인 시 자동 시작 -->
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/jtchoi/Projects/cube-brain-trainer/tools/claude-telegram-bot/bot.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jtchoi/Projects/cube-brain-trainer/tools/claude-telegram-bot/bot.error.log</string>
</dict>
</plist>
